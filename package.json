{
  "name": "hanouti-desktop",
  "version": "1.0.11",
  "description": "Hanouti — Smart Inventory & POS desktop application (Electron + FastAPI)",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/khalilkorichi/hanouti",
  "repository": {
    "type": "git",
    "url": "https://github.com/khalilkorichi/hanouti.git"
  },
  "bugs": {
    "url": "https://github.com/khalilkorichi/hanouti/issues",
    "email": "khalil@hanouti.app"
  },
  "author": {
    "name": "Khalil Korichi",
    "email": "khalil@hanouti.app",
    "url": "https://github.com/khalilkorichi"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend:dev": "cd backend && python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "backend:build": "python backend/build_exe.py",
    "electron:dev": "cross-env HANOUTI_DEV=1 electron .",
    "electron:start": "electron .",
    "build:all": "npm run frontend:build && npm run backend:build",
    "stage:app-files": "node scripts/stage-app-files.cjs",
    "build:manifest": "node scripts/build-manifest.cjs",
    "build:frontend-archive": "node scripts/build-frontend-archive.cjs",
    "dist:win": "npm run build:all && npm run stage:app-files && electron-builder --win --x64 --publish never && npm run build:manifest && npm run build:frontend-archive",
    "dist:dir": "npm run build:all && npm run stage:app-files && electron-builder --dir && npm run build:manifest && npm run build:frontend-archive",
    "postinstall": "electron-builder install-app-deps || true"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-log": "^5.2.0"
  }
}
